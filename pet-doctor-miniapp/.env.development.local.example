# 复制本文件为 .env.development.local（已被 gitignore，不会提交）

# 微信小程序 AppID（在 https://mp.weixin.qq.com 注册后获取，格式 wx 开头 18 位）
VITE_WX_APPID=wx你的AppID

# 后端地址（开发者工具模拟器可用 localhost；真机调试改为电脑局域网 IP）
VITE_API_BASE_URL=http://localhost:8080

# iconfont 在线 ttf 地址（项目 AI宠物医生 → 查看在线链接 → 复制 ttf url，可选）
# VITE_ICONFONT_FONT_URL=https://at.alicdn.com/t/c/font_xxxx.ttf
